<?xml version="1.0"?>
<ruleset name="MonriClient">
    <description>PSR-12 coding standard for Monri Client</description>

    <rule ref="PSR12">
        <!-- php-cs-fixer handles anonymous class braces differently -->
        <exclude name="PSR12.Classes.AnonClassDeclaration.OpenBraceSameLine"/>
    </rule>

    <file>src/</file>
    <file>tests/</file>

    <!-- Exclude standalone router scripts (side-effects by design) -->
    <exclude-pattern>tests/Http/server_router.php</exclude-pattern>
    <exclude-pattern>tests/MockServer/router.php</exclude-pattern>

    <arg name="colors"/>
    <arg value="sp"/>
</ruleset>
